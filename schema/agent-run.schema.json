{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://humanize.local/schema/agent-run.schema.json",
  "title": "Agent Run",
  "type": "object",
  "required": ["schema_version", "created_at", "paper_hash", "input_sources", "budget_profile", "unsupported_items", "risk_level", "privacy_mode", "run_id", "role", "parent_run_id", "independence_group", "provider", "model", "effort", "tool_policy", "workspace_scope", "write_policy", "network_policy", "timeout_seconds", "input_artifacts", "output_artifacts", "summary_artifact", "redaction_status", "started_at", "ended_at", "exit_status"],
  "properties": {
    "schema_version": {"type": "string"},
    "created_at": {"type": "string"},
    "paper_hash": {"type": "string"},
    "input_sources": {"type": "array"},
    "budget_profile": {"type": "string"},
    "unsupported_items": {"type": "array"},
    "risk_level": {"type": "string"},
    "privacy_mode": {"type": "string"},
    "run_id": {"type": "string"},
    "role": {"type": "string"},
    "parent_run_id": {"type": ["string", "null"]},
    "independence_group": {"type": ["string", "null"]},
    "provider": {"type": "string"},
    "model": {"type": "string"},
    "effort": {"type": "string"},
    "tool_policy": {"type": "object"},
    "workspace_scope": {"type": "string"},
    "write_policy": {"type": "string"},
    "network_policy": {"type": "string"},
    "timeout_seconds": {"type": "integer", "minimum": 1},
    "input_artifacts": {"type": "array"},
    "output_artifacts": {"type": "array"},
    "summary_artifact": {"type": ["string", "null"]},
    "redaction_status": {"enum": ["not_needed", "redacted", "blocked"]},
    "started_at": {"type": "string"},
    "ended_at": {"type": ["string", "null"]},
    "exit_status": {"type": "string"}
  },
  "additionalProperties": true
}
