{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://humanize.local/schema/reproduction-plan.schema.json",
  "title": "Paper Reproduction Plan Manifest",
  "type": "object",
  "required": [
    "schema_version",
    "created_at",
    "paper_hash",
    "input_sources",
    "budget_profile",
    "unsupported_items",
    "risk_level",
    "privacy_mode",
    "paper",
    "workspace",
    "safety",
    "budget",
    "feasibility",
    "evidence_map",
    "decomposition",
    "criteria",
    "artifact_profile",
    "assumption_ledger",
    "checkpoint_graph",
    "tasks",
    "provider_roles",
    "agent_runs",
    "review_policy",
    "final_package_contract"
  ],
  "properties": {
    "schema_version": {"type": "string"},
    "created_at": {"type": "string"},
    "paper_hash": {"type": "string"},
    "input_sources": {"type": "array", "minItems": 1},
    "budget_profile": {"type": "string"},
    "unsupported_items": {"type": "array"},
    "risk_level": {"type": "string"},
    "privacy_mode": {"type": "string"},
    "paper": {"type": "object"},
    "workspace": {"type": "object", "required": ["path"]},
    "safety": {"type": "object"},
    "budget": {"type": "object"},
    "feasibility": {"type": "object"},
    "evidence_map": {"type": "object", "required": ["claims", "methods", "experiments", "ambiguities"]},
    "decomposition": {"type": "object", "required": ["modules"], "properties": {"modules": {"type": "array", "items": {"$ref": "#/$defs/paper_module"}}}},
    "criteria": {"type": "array", "items": {"$ref": "#/$defs/criterion"}},
    "artifact_profile": {"type": "object"},
    "assumption_ledger": {"type": "array"},
    "checkpoint_graph": {"type": "object", "required": ["checkpoints"], "properties": {"checkpoints": {"type": "array", "items": {"$ref": "#/$defs/checkpoint"}}}},
    "tasks": {"type": "array", "items": {"$ref": "#/$defs/task"}},
    "provider_roles": {"type": "object"},
    "agent_runs": {"type": "array", "items": {"$ref": "#/$defs/agent_run"}},
    "review_policy": {"type": "object"},
    "final_package_contract": {"type": "object"}
  },
  "$defs": {
    "paper_module": {
      "type": "object",
      "required": ["module_id", "module_type", "origin", "origin_source", "title", "paper_evidence", "depends_on", "claims_supported", "reproduction_needs", "expected_artifact_kinds", "verification_targets", "ambiguities", "risk_level"],
      "properties": {
        "module_id": {"type": "string"},
        "module_type": {"enum": ["algorithm_module", "optimization_module", "data_module", "experiment_design_module", "environment_module", "evaluation_module", "reporting_module", "integration_module"]},
        "origin": {"enum": ["paper", "reproduction_contract", "policy", "assumption"]},
        "origin_source": {"type": "string"},
        "title": {"type": "string"},
        "paper_evidence": {"type": "array"},
        "depends_on": {"type": "array"},
        "claims_supported": {"type": "array"},
        "reproduction_needs": {"type": "array"},
        "expected_artifact_kinds": {"type": "array"},
        "verification_targets": {"type": "array"},
        "ambiguities": {"type": "array"},
        "risk_level": {"type": "string"}
      },
      "additionalProperties": true
    },
    "criterion": {
      "type": "object",
      "required": ["criterion_id", "module_ids", "type", "paper_evidence", "expected_artifacts", "expected_artifact_kinds", "expected_outputs", "verification_method", "status", "blocking", "open_questions"],
      "properties": {
        "criterion_id": {"type": "string"},
        "module_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "type": {"enum": ["claim", "method", "data", "metric", "experiment", "environment", "artifact", "report"]},
        "paper_evidence": {"type": "array"},
        "expected_artifacts": {"type": "array"},
        "expected_artifact_kinds": {"type": "array"},
        "expected_outputs": {"type": "array"},
        "verification_method": {"type": "string"},
        "tolerance": {},
        "status": {"type": "string"},
        "blocking": {"type": "boolean"},
        "open_questions": {"type": "array"}
      },
      "additionalProperties": true
    },
    "checkpoint": {
      "type": "object",
      "required": ["checkpoint_id", "kind", "title", "depends_on", "covered_modules", "covered_criteria", "expected_artifacts", "verification_commands", "reviewer_count", "reviewer_run_ids", "reviewer_provider_policy", "base_snapshot", "target_snapshot", "changed_paths", "artifact_hashes", "checkpoint_base_commit", "acceptance_rule", "open_question_policy", "fallback_policy", "failure_escalation"],
      "not": {"required": ["commands"]},
      "properties": {
        "checkpoint_id": {"type": "string"},
        "kind": {"enum": ["child", "parent"]},
        "title": {"type": "string"},
        "depends_on": {"type": "array"},
        "covered_modules": {"type": "array", "minItems": 1},
        "covered_criteria": {"type": "array", "minItems": 1},
        "expected_artifacts": {"type": "array"},
        "verification_commands": {"type": "array"},
        "reviewer_count": {"type": "integer", "minimum": 1},
        "reviewer_run_ids": {"type": "array"},
        "reviewer_provider_policy": {"type": "object"},
        "base_snapshot": {},
        "target_snapshot": {},
        "changed_paths": {"type": "array"},
        "artifact_hashes": {"type": "object"},
        "checkpoint_base_commit": {},
        "acceptance_rule": {"type": "string"},
        "open_question_policy": {"type": "string"},
        "fallback_policy": {"type": "string"},
        "failure_escalation": {"type": "string"}
      },
      "additionalProperties": true
    },
    "task": {
      "type": "object",
      "required": ["task_id", "title", "lineage_mode", "module_ids", "criterion_ids", "checkpoint_id", "expected_files", "commands", "risk_level", "budget_impact"],
      "allOf": [
        {
          "if": {
            "properties": {"lineage_mode": {"const": "single"}},
            "required": ["lineage_mode"]
          },
          "then": {
            "required": ["primary_module_id", "primary_criterion_id"],
            "properties": {
              "module_ids": {"type": "array", "minItems": 1, "maxItems": 1, "items": {"type": "string"}},
              "criterion_ids": {"type": "array", "minItems": 1, "maxItems": 1, "items": {"type": "string"}}
            }
          }
        },
        {
          "if": {
            "properties": {"lineage_mode": {"const": "primary"}},
            "required": ["lineage_mode"]
          },
          "then": {
            "required": ["primary_module_id", "primary_criterion_id"]
          }
        },
        {
          "if": {
            "properties": {"lineage_mode": {"const": "multi_equal"}},
            "required": ["lineage_mode"]
          },
          "then": {
            "not": {
              "anyOf": [
                {"required": ["primary_module_id"]},
                {"required": ["primary_criterion_id"]}
              ]
            }
          }
        }
      ],
      "properties": {
        "task_id": {"type": "string"},
        "title": {"type": "string"},
        "lineage_mode": {"enum": ["single", "primary", "multi_equal"]},
        "primary_module_id": {"type": "string"},
        "module_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "primary_criterion_id": {"type": "string"},
        "criterion_ids": {"type": "array", "minItems": 1, "items": {"type": "string"}},
        "checkpoint_id": {"type": "string"},
        "expected_files": {"type": "array"},
        "commands": {"type": "array"},
        "risk_level": {"type": "string"},
        "budget_impact": {"type": "string"}
      },
      "additionalProperties": true
    },
    "agent_run": {
      "type": "object",
      "required": ["run_id", "role", "parent_run_id", "independence_group", "provider", "model", "effort", "tool_policy", "workspace_scope", "write_policy", "network_policy", "timeout_seconds", "input_artifacts", "output_artifacts", "summary_artifact", "redaction_status", "started_at", "ended_at", "exit_status"],
      "properties": {
        "run_id": {"type": "string"},
        "role": {"type": "string"},
        "parent_run_id": {"type": ["string", "null"]},
        "independence_group": {"type": ["string", "null"]},
        "provider": {"type": "string"},
        "model": {"type": "string"},
        "effort": {"type": "string"},
        "tool_policy": {"type": "object"},
        "workspace_scope": {"type": "string"},
        "write_policy": {"type": "string"},
        "network_policy": {"type": "string"},
        "timeout_seconds": {"type": "integer", "minimum": 1},
        "input_artifacts": {"type": "array"},
        "output_artifacts": {"type": "array"},
        "summary_artifact": {"type": ["string", "null"]},
        "redaction_status": {"enum": ["not_needed", "redacted", "blocked"]},
        "started_at": {"type": "string"},
        "ended_at": {"type": ["string", "null"]},
        "exit_status": {"type": "string"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
